Algoritmo "Antecessor_Sucessor"

Var
   numero, antecessor, sucessor: INTEIRO

Inicio

   ESCREVA("Digite um n·mero inteiro: ")
   LEIA(numero)

   antecessor <- numero - 1
   sucessor <- numero + 1

   ESCREVAL("O n·mero digitado foi: ", numero)
   ESCREVAL("O seu antecessor ķ: ", antecessor)
   ESCREVAL("O seu sucessor ķ: ", sucessor)

Fimalgoritmo