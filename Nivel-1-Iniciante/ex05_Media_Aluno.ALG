Algoritmo "Nota"

Var
Nome: Caractere
Nota1, Nota2, M: REAL

Inicio

      ESCREVA("ESCREVA seu nome: ")
      Leia(nome)
      ESCREVA("escreva a nota1: ")
      LEIA(Nota1)
      ESCREVA("escreva a nota2: ")
      LEIA(Nota2)
      M <- (Nota1 + Nota2)/2
      ESCREVA("A MEDIA ENTRE ", NOTA1, " E ", NOTA2, " E IGUAL A ", M)


Fimalgoritmo